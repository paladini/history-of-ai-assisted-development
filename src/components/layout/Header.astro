---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: base, label: 'Timeline' },
  { href: `${base}data/`, label: 'Data' },
  { href: `${base}glossary/prompts/`, label: 'Glossary' },
  { href: `${base}about/`, label: 'About' },
];

function isActive(href: string) {
  if (href === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4" aria-label="Main navigation">
    <a href={base} class="font-serif text-xl text-[var(--color-text)] no-underline hover:text-[var(--color-copilot)]">
      AI Dev History
    </a>
    <ul class="flex items-center gap-1 sm:gap-4">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'rounded-md px-3 py-1.5 text-sm no-underline transition-colors',
              isActive(link.href)
                ? 'bg-[var(--color-bg-elevated)] text-[var(--color-text)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
